# Copy to .env and fill in real values. Never commit .env.

# Anthropic API key, used by the judge runner's provider interface (see docs/architecture.md).
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# OpenAI API key, used only if you configure an OpenAI-backed judge scorer.
OPENAI_API_KEY=sk-...your-key-here

# SQLite path for the dataset/run store (v0). Swapped for Postgres when the dashboard milestone lands.
JUDGEKIT_DB_PATH=./judgekit.db

# Default judge model pin (rubric prompts + params must stay pinned per calibration report; see ADR-0002).
JUDGEKIT_JUDGE_MODEL=claude-sonnet-4-5

# Log level for the CLI and library.
JUDGEKIT_LOG_LEVEL=INFO
