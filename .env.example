# Copy to .env and fill in real values. Never commit .env.

# Anthropic API key, read by the "anthropic" judge provider at call time.
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# API key for the "openai-compatible" judge provider (OpenAI, vLLM, Ollama, gateways).
# The env var name itself is configurable per judge config via "api_key_env".
OPENAI_API_KEY=sk-...your-key-here

# SQLite path for a future run store; dormant until the dashboard milestone (see ADR-0003).
JUDGEKIT_DB_PATH=./judgekit.db

# Log level for the CLI and library.
JUDGEKIT_LOG_LEVEL=INFO
